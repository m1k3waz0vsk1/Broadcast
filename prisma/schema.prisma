// Prisma schema for the Broadcast graphics marketplace.
// Uses Postgres (e.g. Neon) — DATABASE_URL points at the same database for
// local dev and production so migration history stays consistent.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth (NextAuth / Auth.js) ----------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  cartItems     CartItem[]
  orders        Order[]
  subscriptions Subscription[]

  stripeCustomerId String? @unique
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Catalog ----------

// ProductType values: "PACKAGE" (one-time purchase, individual graphics package)

model Category {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  products Product[]
}

model Product {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  tagline     String
  description String
  type        String      @default("PACKAGE")
  priceCents  Int
  currency    String      @default("usd")
  coverImage  String
  previewImages String // JSON-encoded string[]
  formats     String // JSON-encoded string[] e.g. ["PNG","PSD","After Effects"]
  featured    Boolean     @default(false)

  stripePriceId String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  assets     ProductAsset[]
  orderItems OrderItem[]
  cartItems  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Downloadable files bundled inside a purchased package.
model ProductAsset {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  fileName  String
  filePath  String // path within the protected /content directory
  sizeBytes Int
}

// ---------- Subscription plan (full-library access) ----------

model Plan {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  description   String
  priceCents    Int
  currency      String   @default("usd")
  interval      String // "month" | "year"
  stripePriceId String?

  subscriptions Subscription[]
}

// SubscriptionStatus values: "ACTIVE" | "TRIALING" | "PAST_DUE" | "CANCELED" | "INCOMPLETE"

model Subscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  stripeSubscriptionId String   @unique
  status                String
  currentPeriodEnd      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- Cart ----------

model CartItem {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

// ---------- Orders ----------

// OrderStatus values: "PENDING" | "PAID" | "FAILED" | "REFUNDED"

model Order {
  id         String @id @default(cuid())
  userId     String
  user       User   @relation(fields: [userId], references: [id])
  status     String @default("PENDING")
  totalCents Int
  currency   String @default("usd")

  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  priceCents Int
  quantity   Int     @default(1)
}
