# Postgres connection string (e.g. from Neon: https://console.neon.tech)
# Use the "pooled connection" string Neon gives you.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth / Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (create credentials at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe (get test keys at https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

APP_URL="http://localhost:3000"
